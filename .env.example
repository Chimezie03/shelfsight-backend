
DATABASE_URL=

DIRECT_URL=

# JWT
JWT_SECRET=change-me-to-a-random-secret

# Public web app URL (password reset links, invites). Defaults to http://localhost:3000
WEB_BASE_URL=http://localhost:3000

# Resend (https://resend.com) — password reset emails. If unset, reset links are only logged server-side.
RESEND_API_KEY=
# Optional. Default: onboarding@resend.dev (Resend test sender; verify a domain for production mail).
EMAIL_FROM=

# AWS Configuration (for S3 upload, SQS queue & Textract OCR)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
SQS_QUEUE_URL=

# OpenAI Configuration (for Dewey Decimal classification)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Optional: Google Books API key for higher-volume ISBN metadata (fallback after Open Library)
GOOGLE_BOOKS_API_KEY=

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  users         User[]
  books         Book[]
  bookCopies    BookCopy[]
  loans         Loan[]
  fines         Fine[]
  transactions  TransactionLog[]
  shelves       ShelfSection[]
  ingestionJobs IngestionJob[]
  invites       Invite[]
}

model Invite {
  id             String       @id @default(uuid())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  email          String?
  role           Role
  tokenHash      String       @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  acceptedUserId String?
  createdById    String
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
  @@index([expiresAt])
}

model User {
  id             String       @id @default(uuid())
  email          String
  passwordHash   String
  name           String
  role           Role
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  loans          Loan[]

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin)
}

enum Role {
  ADMIN
  STAFF
  PATRON
}

model Book {
  id             String       @id @default(uuid())
  title          String
  author         String
  isbn           String
  genre          String?
  deweyDecimal   String?
  language       String       @default("English")
  coverImageUrl  String?
  publishYear    String?
  pageCount      Int?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  copies         BookCopy[]

  @@unique([organizationId, isbn])
  @@index([organizationId])
  @@index([createdAt])
  @@index([language])
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([author(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([genre])
}

model BookCopy {
  id             String          @id @default(uuid())
  book           Book            @relation(fields: [bookId], references: [id])
  bookId         String
  barcode        String
  status         CopyStatus      @default(AVAILABLE)
  shelf          ShelfSection?   @relation(fields: [shelfId], references: [id])
  shelfId        String?
  organization   Organization    @relation(fields: [organizationId], references: [id])
  organizationId String
  loans          Loan[]
  events         BookCopyEvent[]

  @@unique([organizationId, barcode])
  @@index([organizationId])
  @@index([bookId])
  @@index([shelfId])
}

enum CopyStatus {
  AVAILABLE
  CHECKED_OUT
  LOST
  PROCESSING
}

model BookCopyEvent {
  id         String        @id @default(uuid())
  bookCopy   BookCopy      @relation(fields: [bookCopyId], references: [id])
  bookCopyId String
  type       CopyEventType
  userId     String?
  shelfId    String?
  loanId     String?
  note       String?
  createdAt  DateTime      @default(now())

  @@index([bookCopyId, createdAt])
}

enum CopyEventType {
  CHECKED_OUT
  RETURNED
  SHELVED
  MOVED
  MARKED_LOST
  MARKED_PROCESSING
}

model Loan {
  id             String       @id @default(uuid())
  user           User         @relation(fields: [userId], references: [id])
  userId         String
  bookCopy       BookCopy     @relation(fields: [bookCopyId], references: [id])
  bookCopyId     String
  checkedOutAt   DateTime     @default(now())
  dueDate        DateTime
  returnedAt     DateTime?
  fineAmount     Float        @default(0)
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  fines          Fine[]

  @@index([organizationId])
  @@index([userId, checkedOutAt])
  @@index([bookCopyId, returnedAt])
  @@index([returnedAt, dueDate])
}

model Fine {
  id             String       @id @default(uuid())
  loan           Loan         @relation(fields: [loanId], references: [id])
  loanId         String
  userId         String
  amount         Float
  status         FineStatus   @default(UNPAID)
  reason         String       @default("Overdue")
  paidAt         DateTime?
  waivedBy       String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String

  @@index([organizationId])
  @@index([userId, status])
  @@index([loanId])
  @@index([createdAt])
}

enum FineStatus {
  UNPAID
  PAID
  WAIVED
}

model TransactionLog {
  id             String          @id @default(uuid())
  type           TransactionType
  loanId         String?
  bookTitle      String
  memberName     String
  memberNumber   String
  processedBy    String
  details        String
  createdAt      DateTime        @default(now())
  organization   Organization    @relation(fields: [organizationId], references: [id])
  organizationId String

  @@index([organizationId])
  @@index([type, createdAt])
  @@index([createdAt])
  @@index([bookTitle(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([memberName(ops: raw("gin_trgm_ops"))], type: Gin)
}

enum TransactionType {
  CHECKOUT
  CHECKIN
  RENEWAL
  FINE_PAID
  FINE_WAIVED
}

model ShelfSection {
  id              String       @id @default(uuid())
  label           String
  mapX            Int
  mapY            Int
  width           Int
  height          Int
  floor           Int
  sectionCode     String?
  category        String?      @default("Uncategorized")
  deweyRangeStart String?
  deweyRangeEnd   String?
  numberOfTiers   Int?         @default(4)
  capacityPerTier Int?         @default(30)
  color           String?      @default("#1B2A4A")
  rotation        Int?         @default(0)
  notes           String?
  shelfType       String?      @default("single-shelf")
  organization    Organization @relation(fields: [organizationId], references: [id])
  organizationId  String
  copies          BookCopy[]

  @@index([organizationId])
  @@index([floor])
}

model IngestionJob {
  id                   String          @id @default(uuid())
  imageUrl             String
  status               IngestionStatus @default(PENDING)
  ocrText              String?
  detectedIsbn         String?
  suggestedDewey       String?
  confidenceScore      Float?
  suggestedTitle       String?
  suggestedAuthor      String?
  suggestedPublisher   String?
  suggestedPublishDate String?
  suggestedGenre       String?
  coverImageUrl        String?
  metadataSource       String?
  deweyReasoning       String?
  language             String?
  reviewedBy           String?
  reviewedAt           DateTime?
  createdBookId        String?
  createdAt            DateTime        @default(now())
  organization         Organization    @relation(fields: [organizationId], references: [id])
  organizationId       String

  @@index([organizationId])
  @@index([createdAt])
  @@index([status, createdAt])
}

enum IngestionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  APPROVED
  REJECTED
}
